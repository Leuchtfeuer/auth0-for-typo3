    "symfony/http-foundation": "^5.4.50 || ^7.3.7",
    "symfony/property-access": "^4.4 || ^5.4 || ^7.0",
    "symfony/property-info": "^5.4 || ^7.0",
    "symfony/serializer": "^4.4 || ^5.4 || ^7.0",
    "nyholm/psr7": "^1.8"
